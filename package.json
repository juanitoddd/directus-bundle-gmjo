{
  "name": "directus-bundle-gmjo",
  "version": "0.1.0",
  "type": "module",
  "description": "GMJO project Directus bundle (panels, interfaces, tools).",
  "keywords": [
    "directus",
    "directus-extension",
    "directus-custom-bundle"
  ],
  "directus:extension": {
    "type": "bundle",
    "path": {
      "app": "dist/app.js",
      "api": "dist/api.js"
    },
    "entries": [
      {
        "type": "panel",
        "name": "flow-triggers",
        "source": "src/flow-triggers/index.ts"
      },
      {
        "type": "interface",
        "name": "custom-editor",
        "source": "src/custom-editor/index.ts"
      },
      {
        "type": "layout",
        "name": "tree-view-table-layout",
        "source": "src/tree-view-table-layout/src/index.ts"
      }
    ],
    "host": "^10.10.0 || ^11.0.0"
  },
  "scripts": {
    "build": "directus-extension build",
    "dev": "directus-extension build -w --no-minify",
    "link": "directus-extension link .",
    "add": "directus-extension add"
  },
  "devDependencies": {
    "@directus/extensions-sdk": "^17.1.4",
    "@directus/utils": "^12.0.4",
    "@json2csv/plainjs": "^7.0.6",
    "@editorjs/attaches": "^1.3.0",
    "@editorjs/checklist": "1.6.0",
    "@editorjs/code": "2.9.0",
    "@editorjs/delimiter": "1.4.0",
    "@editorjs/editorjs": "^2.31.6",
    "@editorjs/embed": "2.7.4",
    "@editorjs/header": "2.8.1",
    "@editorjs/image": "2.9.3",
    "@editorjs/inline-code": "1.5.0",
    "@editorjs/nested-list": "1.4.3",
    "@editorjs/paragraph": "2.11.5",
    "@editorjs/quote": "2.6.0",
    "@editorjs/raw": "2.5.0",
    "@editorjs/table": "2.3.0",
    "@editorjs/underline": "1.1.0",
    "@types/dompurify": "^3.0.5",
    "@types/lodash": "^4.17.24",
    "@types/file-saver": "^2.0.7",
    "@vueuse/core": "^12.0.0",
    "file-saver": "^2.0.5",
    "lodash": "^4.17.21",
    "editorjs-toggle-block": "^0.3.16",
    "sass": "^1.99.0",
    "typescript": "^5.5.0",
    "vue": "^3.4.0",
    "vue-i18n": "^9.13.1",
    "vue-router": "^4.4.3",
    "vuedraggable": "4.1.0"
  },
  "dependencies": {
    "dompurify": "^3.4.9",
    "editorjs-color-picker": "^1.0.8"
  }
}
